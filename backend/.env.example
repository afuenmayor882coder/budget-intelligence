# Budget Intelligence Backend Configuration
# Copy this file to .env and fill in your values

# App
DEBUG=false

# Rate Source: github | google_sheets | onedrive | local_only
RATE_SOURCE=local_only

# Option A1: GitHub Actions (recommended)
# RATE_SOURCE=github
# GITHUB_RATES_URL=https://raw.githubusercontent.com/YOUR_USER/YOUR_REPO/main/cloud-automation/github-actions/data/rates.csv
# GITHUB_CESTA_URL=https://raw.githubusercontent.com/YOUR_USER/YOUR_REPO/main/cloud-automation/github-actions/data/cesta_basica.csv

# Option A2: Google Sheets
# RATE_SOURCE=google_sheets
# GOOGLE_SHEET_ID=your_google_sheet_id_here

# Narrative density: concise | normal | detailed
NARRATIVE_DENSITY=normal

# LLM (optional, Phase 5 only)
# LLM_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
